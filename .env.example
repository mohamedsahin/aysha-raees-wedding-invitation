# Copy to .env.local and fill in. .env.local is gitignored.

# Neon Postgres connection string (Project → Connection Details).
DATABASE_URL='postgresql://USER:PASSWORD@HOST/DB?sslmode=require'

# Single admin login for the /admin analytics dashboard.
ADMIN_EMAIL='you@example.com'
ADMIN_PASSWORD='change-me'

# Random 32+ byte secret used to sign the admin session cookie.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET='change-me-to-a-long-random-string'
